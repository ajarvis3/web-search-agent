{
  "info": {
    "_postman_id": "f2c6d0a8-6b2a-4a3b-9e9d-1f2d3c4b5a6e",
    "name": "web-search-agent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the web-search-agent Flask app (health + search endpoints)."
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Simple liveness check returning {\"status\": \"ok\"}."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var body = pm.response.json();",
              "pm.test(\"Body contains status: ok\", function () {",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": []
    },
    {
      "name": "Search (POST JSON body)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"What is the capital of France?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/search",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "search"
          ]
        },
        "description": "Post a JSON body with {\"query\": \"...\"} to receive an {\"answer\": ...} response."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response contains answer or error\", function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body).to.be.an('object');",
              "    pm.expect((body.answer !== undefined) || (body.error !== undefined)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": []
    },
    {
      "name": "Search (GET query param)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/search?query=What%20is%20Python",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "search"
          ],
          "query": [
            {
              "key": "query",
              "value": "What is Python",
              "description": "URL-encoded query parameter"
            }
          ]
        },
        "description": "GET search endpoint that accepts the `query` URL parameter."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response contains answer or error\", function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body).to.be.an('object');",
              "    pm.expect((body.answer !== undefined) || (body.error !== undefined)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "default"
    }
  ]
}

