# Google Gemini API key — obtain from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_KEY=your_tavily_key_here

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
